rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the caller is the hardcoded admin
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == "2002dineshmurugan@gmail.com";
    }

    // ── Users collection ──────────────────────────────────────────────────────
    // Each user may only read/write their own document.
    // Admin can read and write any user document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read, write: if isAdmin();
    }

    // ── Weight history ────────────────────────────────────────────────────────
    // Users may only create entries that belong to them.
    // Users may read only their own entries.
    // Admin can read/write/delete everything.
    match /weight_history/{docId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
      allow update: if isAdmin();
    }

    // Deny everything else by default
  }
}
